<script @_Fun3.Script("Survey")></script>
<vc:xg-prog-path />
<div class="x-prog">
    <div id="divRead">
        <form id='formRead' class='x-form'>
            <div class="row">
                <div class="col-md-2 x-label">填寫時間</div>
                <div class="col-md-10 x-input x-hbox">
                    @await Component.InvokeAsync(XiEstr.Date, new XiDateDto { Fid = "Created", InRow = true })
                    <span>～</span>
                    @await Component.InvokeAsync(XiEstr.Date, new XiDateDto { Fid = "Created2", InRow = true })
                    @await Component.InvokeAsync("XgFindTbar", new XgFindTbarDto { HasReset = true })
                </div>
            </div>
        </form>

        <table id="tableRead" class="table table-bordered x-table" cellspacing="0">
            <thead>
                <tr>
                    <th>問題Id</th>
                    <th>標題</th>
                    <th>建議內容</th>
                    <th>填寫時間</th>                    
                    <th width='100px'>維護</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>

    <div id="divEdit" class="d-none">
        <partial name="Edit" />
    </div>
</div>