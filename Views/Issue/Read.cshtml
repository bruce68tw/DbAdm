<vc:xg-prog-path />
<div class="x-prog">
    <div id="divRead">
        <form id='formRead' class='x-form mb-0'>
            <div class="row">
                @await Component.InvokeAsync(XiEstr.Select, new XiSelectDto { Title = "專案", Fid = "_ProjectId", Rows = ViewBag.Projects, InRow = true, FnOnChange = "_me.onChgProject", EventArgs = "0" })
                @await Component.InvokeAsync("XgFindTbar", new XgFindTbarDto { HasReset = true, HasFind2 = true })
            </div>
            @await Component.InvokeAsync(XiEstr.Select, new XiSelectDto { Title = "專案功能", Fid = "ProgId", Rows = ViewBag.PrjProgs })
            @await Component.InvokeAsync(XiEstr.Select, new XiSelectDto { Title = "資料種類", Fid = "IssueType", Rows = ViewBag.IssueTypes })
            @* 底線欄位 _IsWatch 在後端用程式調整sql *@
            @await Component.InvokeAsync(XiEstr.Text, new XiTextDto { Title = "回報人員", Fid = "RptUser" })
            @await Component.InvokeAsync(XiEstr.Select, new XiSelectDto { Title = "處理人員", Fid = "OwnerId", Rows = ViewBag.Users })
            <div class="row">
                <div class="col-md-2 x-label">工作日期</div>
                <div class="col-md-10 x-input x-hbox">
                    @await Component.InvokeAsync(XiEstr.Date, new XiDateDto { Fid = "WorkDate", InRow = true })
                    <span>～</span>
                    @await Component.InvokeAsync(XiEstr.Date, new XiDateDto { Fid = "WorkDate2", InRow = true })
                </div>
            </div>
        </form>

        <form id='formRead2' class='x-form mb-0 d-none'>
            @await Component.InvokeAsync(XiEstr.Text, new XiTextDto { Title = "工作標題", Fid = "Title" })
            @await Component.InvokeAsync(XiEstr.Select, new XiSelectDto { Title = "已結案", Fid = "IsFinish", Rows = ViewBag.YesNos })
            @await Component.InvokeAsync(XiEstr.Select, new XiSelectDto { Title = "已追踪", Fid = "_IsWatch", Rows = ViewBag.YesNos })
            @await Component.InvokeAsync(XiEstr.Select, new XiSelectDto { Title = "有回報人", Fid = "_HasRptUser", Rows = ViewBag.YesNos })
            @await Component.InvokeAsync(XiEstr.Select, new XiSelectDto { Title = "有收問卷", Fid = "_HasSurvey", Rows = ViewBag.YesNos })
            @await Component.InvokeAsync(XiEstr.Select, new XiSelectDto { Title = "交辦主管", Fid = "FromMgr", Rows = ViewBag.Users })
            <div class="row">
                <div class="col-md-2 x-label">建檔日期</div>
                <div class="col-md-10 x-input x-hbox">
                    @await Component.InvokeAsync(XiEstr.Date, new XiDateDto { Fid = "Created", InRow = true })
                    <span>～</span>
                    @await Component.InvokeAsync(XiEstr.Date, new XiDateDto { Fid = "Created2", InRow = true })
                </div>
            </div>
        </form>
        <div class="x-h10"></div>

		<div class='x-btns-box'>
			<vc:xg-create/>
            <button type="button" class="btn btn-secondary" data-onclick="_me.onMyToday">我的今天資料</button>
            <button type="button" class="btn btn-secondary" data-onclick="_me.onMyWeek">我的本週資料</button>
            <button type="button" class="btn btn-secondary" data-onclick="_me.onMyNotFinish">我的未結案</button>
            <button type="button" class="btn btn-secondary" data-onclick="_me.onMyWatch">我的追踪</button>
            <button type="button" class="btn btn-secondary" data-onclick="_me.onMyAskAll">我的交辦(全部)</button>
            <button type="button" class="btn btn-secondary" data-onclick="_me.onMyAskPend">我的交辦(未完成)</button>
            <span class="p-1">工作時數合計：<span id="SumHours"></span></span>
        </div>
        <table id="tableRead" class="table table-bordered x-table" cellspacing="0">
            <thead>
                <tr>
					<th>專案</th>
                    <th>專案功能</th>
                    <th>資料種類</th>
                    <th>工作日期</th>
                    <th>工作時數</th>
                    <th>資料Id</th>
                    <th max-width='300px'>標題</th>
                    <th min-width='65px'>已結案</th>
                    <th min-width='65px'>交辦主管</th>
                    <th min-width='65px'>處理人員</th>
                    <th min-width='65px'>寄送次數</th>
                    <th min-width='65px'>已填問卷</th>
                    <th width ='90px'>功能</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>

    <div id="divEdit" class="d-none">
        <partial name="Edit" />
    </div>
</div>