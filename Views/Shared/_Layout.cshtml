@using Base.Models
@using DbAdm.Services
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery

@{
    var libVer = _Xp.LibVer;
    var myVer = _Xp.MyVer;
    var min = _Fun.IsDev ? "" : ".min";   //min js
    var locale = _Locale.GetLocale();
    var nonce = _Fun.Nonce;
    var menus = await _Auth.GetMenu1A("SetPwd");
}

<style nonce="@_Fun.Nonce">
    .xu-logo {
        height: 36px;
        width: auto;
        padding-right: 6px;
    }
</style>

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@_Fun.Config.SystemName</title>
    <meta name="viewport" content="width=device-width, minimum-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <!-- 防止 CSRF  -->
    <meta name="csrf-token" content="@(Antiforgery.GetAndStoreTokens(Context).RequestToken)" />

    <script type="importmap" nonce="@nonce">
    {
      "imports": {
        "@@baseJs": "/base.min.js"
      }
    }
    </script>

    <!-- 1.load css -->
    <link rel="stylesheet" href="~/lib.min.css?v=@libVer" />
    @RenderSection("styles", required: false)

    <!-- 2.load lib js -->
    <script nonce="@nonce" src="~/lib.min.js?v=@libVer"></script>

    <!-- 3.load my site js(debug/production mode) !! -->
    <link rel="stylesheet" href="~/base.min.css?v=@myVer" />
    <script type="module" nonce="@nonce" src="~/base.min.js?v=@myVer"></script>

    <!-- 配色 -->
    <link rel="stylesheet" asp-href-include="~/cssView/_themeLight.css" />
    <link id="xgTheme" rel="stylesheet" asp-href-include="~/cssView/_xgGrey.css" />

    <!-- 4.load local js -->
    <script type="module" nonce="@nonce" src="~/locale/@(locale).min.js?v=@myVer"></script>

    @RenderSection("scripts", required: false)

    <!-- 5.initial -->
    <script type="module" nonce="@nonce">
        import { _Fun } from '/base.min.js';
        $(function () {
            _Fun.init('@locale');
            _Fun.pageRows = 20;
            //_fun.lengthMenu = [10, 20, 50, 100, 150];
            _Fun.userId = '@_Fun.UserId()';
        });
    </script>
</head>

<!-- 6.show view -->
<body class="x-main">
    <!-- Top -->
    <nav class="navbar navbar-expand navbar-dark x-main-top">
        <a class="sidebar-toggle me-3 cursor-pointer" data-onclick="_leftmenu.onToggleMenu">
            <i class="ico-menu"></i>
        </a>

        <!-- Logo -->
        <img src="/image/logo.png" class="xu-logo">

        <div class="title">@_Fun.Config.SystemName</div>
        <div class="navbar-collapse collapse justify-content-end">
            <ul class="navbar-nav ml-auto">
                @*
                <li>
                @Html.XiSelect("_Locale", _Session.Locale, locales, prop: new PropSelectDto() { AddEmptyRow = false, FnOnChange = "_xp.onChangeLocale" })
                </li>
                @{
                    List<IdStrDto> colors = new()
                    {
                        new(){ Id = "Orange", Str = "温馨橘" },
                        new(){ Id = "GreenApple", Str = "蘋果綠" },
                        new(){ Id = "Blue", Str = "舒適藍" },
                        //new(){ Id = "Green", Str = "時尚綠" },
                        new(){ Id = "Grey", Str = "紳士灰" },
                    };
                }
                <li>
                    <vc:xi-select dto='new() { Fid = "Color", Rows = colors, ClsBox = "x-w100", AddEmpty = false, FnOnChange = "_html.loadThemeByElm"}' />
                </li>
                *@
                <li>
                    <a class="nav-link" href="@Url.Action("Index", "Home")">
                        <i class="ico-home"></i>
                    </a>
                </li>
                <li>
                    @_Fun.GetBaseUser().UserName
                </li>
                <li>
                    <a class="nav-link" title="Logout" href="@Url.Action("Logout", "Home")">
                        <i class="ico-exit"></i>
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <div class="x-main-down">
        <!-- left menu -->
        @await Component.InvokeAsync("XgLeftMenu", new { rows = menus })

        <!-- work area -->
        <div class="x-main-right">
            @RenderBody()
        </div>
    </div>

    <!-- tool component -->
    <vc:xg-tool/>
</body>
</html>