<script type="module" nonce="@_Fun.Nonce" src="~/jsView/Table.js@_Fun.Ver()"></script>
<vc:xg-prog-path />
<div class="x-prog">
    <!-- read form-->
    <div id="divRead">
        <!-- condition -->
        <form id='formRead' class='x-form mb-0'>
            <div class="row">
                @await Component.InvokeAsync(XiEstr.Select, new XiSelectDto { Title = "專案", Fid = "ProjectId", Rows = ViewBag.Projects, InRow = true })
                @await Component.InvokeAsync("XgFindTbar", new XgFindTbarDto { HasReset = true, HasFind2 = true })
            </div>
            @await Component.InvokeAsync(XiEstr.Text, new XiTextDto { Title = "資料表", Fid = "Code", MaxLen = 30 })
        </form>
        <form id='formRead2' class='x-form'>
            @await Component.InvokeAsync(XiEstr.Text, new XiTextDto { Title = "資料表名稱", Fid = "Name", MaxLen = 30 })
            @await Component.InvokeAsync(XiEstr.Select, new XiSelectDto { Title = "異動記錄", Fid = "TranLog", Rows = ViewBag.YesNos })
            @await Component.InvokeAsync(XiEstr.Select, new XiSelectDto { Title = "資料狀態", Fid = "Status", Rows = ViewBag.Statuses })
        </form>

        <div class='x-btns-box mt-1'>
            @await Component.InvokeAsync("XgCreate")
            @await Component.InvokeAsync("XgExport")
            <button type="button" class="btn btn-secondary" data-onclick="_vo.onGenWord">產生文件</button>
        </div>

        <!-- result list -->
        <table id="tableRead" class="table table-bordered x-table" cellspacing="0">
            <thead>
                <tr>
                    <th width="60px">選取</th>
                    <th>專案</th>
                    <th>資料庫</th>
                    <th>資料表</th>
                    <th>資料表名稱</th>
                    <th>建檔人員</th>
                    <th width='90px'>異動記錄</th>
                    <th width='90px'>維護</th>
                    <th width='110px'>資料狀態</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>

    <!-- edit form-->
    <div id="divEdit" class="d-none">
        <partial name="Edit" />
    </div>
</div>
