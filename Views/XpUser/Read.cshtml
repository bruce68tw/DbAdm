<script type="module" nonce="@_Fun.Nonce" src="~/jsView/XpUser.js@_Fun.Ver()"></script>
<vc:xg-prog-path />
<div class="x-prog">
    <div id="divRead">
        <form id='formRead' class='x-form'>
            <div class="row">
                <vc:xi-text dto='new() { Title = "帳號", Fid = "Account", MaxLen = 20, InRow = true }' />
                <vc:xg-find-tbar dto='new() { HasReset = true }' />
            </div>
            <vc:xi-text dto='new() { Title = "用戶名稱", Fid = "Name", MaxLen = 20 }' />
            <vc:xi-select dto='new() { Title = "部門", Fid = "DeptId", Rows = ViewBag.Depts }' />
        </form>

        <div class='x-btns-box'>
            <vc:xg-create />
        </div>
        <table id="tableRead" class="table x-table" cellspacing="0">
            <thead>
                <tr>
                    <th>帳號</th>
                    <th>用戶名稱</th>
                    <th>部門名稱</th>
                    <th>資料狀態</th>
                    <th>維護</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>

    <div id="divEdit" class="d-none">
        <form id='eform' class='x-form mb-0'>
            <vc:xi-hide dto='new() { Fid = "Id" }' />
            <vc:xi-text dto='new() { Title = "帳號", Fid = "Account", Required = true, MaxLen = 20 }' />
            <vc:xi-text dto='new() { Title = "用戶名稱", Fid = "Name", Required = true, MaxLen = 20 }' />
            <vc:xi-text dto='new() { Title = "員工編號", Fid = "EmpNo", Required = true, MaxLen = 10 }' />
            <vc:xi-select dto='new() { Title = "部門名稱", Fid = "DeptId", Rows = ViewBag.Depts }' />
            <vc:xi-check dto='new() { Title = "資料狀態", Fid = "Status", Label = "啟用" }' />
        </form>

        <form class='x-form'>
            <div class='row'>
                <div class='col-md-2 x-label'>角色清單</div>
                <div class='col-md-8 x-input'>
                    <table width="100%" border="0" cellspacing="0" cellpadding="0">
                        <tbody>
                            <tr>
                                <td id="divRoles">
                                    @foreach (IdStrDto row in ViewBag.Roles)
                                    {
                                        <vc:xi-check dto='new() { Fid = row.Id, Value = row.Id, Label = row.Str }' />
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </form>
        <vc:xg-save2 />
    </div>
</div>