<script type="module" nonce="@_Fun.Nonce" src="~/jsView/Project.js@_Fun.Ver()"></script>
<vc:xg-prog-path />
<div class="x-prog">
    <!-- read form-->
    <div id="divRead">
        <form id='formRead' class='x-form mb-0'>
            <div class="row">
                @await Component.InvokeAsync(XiEstr.Text, new XiTextDto { Title = "專案名稱", Fid = "Name", InRow = true })
                @await Component.InvokeAsync("XgFindTbar")
            </div>
            @await Component.InvokeAsync(XiEstr.Text, new XiTextDto { Title = "專案代碼", Fid = "Code" })
        </form>

        <div class='x-btns-box'>
            @await Component.InvokeAsync("XgCreate")
        </div>
        <table id="tableRead" class="table table-bordered x-table" cellspacing="0">
            <thead>
                <tr>
                    <th>專案名稱</th>
                    <th>專案代碼</th>
                    <th>資料庫</th>
                    <th>建檔人員</th>
                    <th>功能</th>
                    <th width='90px'>維護</th>
                    <th width='120px'>資料狀態</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>

    <!-- edit form -->
    <div id="divEdit" class="d-none">
        <partial name="Edit" />
    </div>
</div>