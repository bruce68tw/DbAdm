<vc:xg-prog-path />
<div class="x-prog">
    <div id="divRead">
		<form id='formRead' class='x-form'>
            <div class="row">
                @await Component.InvokeAsync(XiEstr.Select, new XiSelectDto { Title = "專案", Fid = "ProjectId", Rows = ViewBag.Projects, InRow = true, FnOnChange = "_vo.onChgProject" })
                @await Component.InvokeAsync("XgFindTbar", new XgFindTbarDto { HasReset = true })
            </div>
            @await Component.InvokeAsync(XiEstr.Select, new XiSelectDto { Title = "資料種類", Fid = "IssueType", Rows = ViewBag.IssueTypes })
            <div class="row">
                <div class="col-md-2 x-label">工作日期</div>
                <div class="col-md-10 x-input">
                    @await Component.InvokeAsync(XiEstr.Date, new XiDateDto { Fid = "WorkDate", InRow = true })
                    <span>～</span>
                    @await Component.InvokeAsync(XiEstr.Date, new XiDateDto { Fid = "WorkDate2", InRow = true })
                </div>
            </div>
        </form>

		<div class='x-btns-box'>
            @await Component.InvokeAsync("XgExport")
            <button type="button" class="btn btn-secondary" data-onclick="_vo.onNowWeek">本週資料</button>
            <button type="button" class="btn btn-secondary" data-onclick="_vo.onNowMonth">本月資料</button>
        </div>
        <table id="tableRead" class="table table-bordered x-table" cellspacing="0">
            <thead>
                <tr>
					<th>專案</th>
                    <th>資料種類</th>
                    <th>資料筆數</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>